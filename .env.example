# Server config
SERVER_URL=http://localhost:8080
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
OPEN_BROWSER=1
# Browser auto-open URL and local hint URL
LOCAL_ACCESS_URL=http://localhost:8080
BROWSER_URL=http://localhost:8080
# Optional manual LAN IP override, e.g. 192.168.1.23
LAN_IP_OVERRIDE=
POLL_INTERVAL=5

# CLI timeout in seconds per task
CLI_TIMEOUT=300

# Agent heartbeat interval (seconds)
HEARTBEAT_SECS=45

# Agent -> server status/output POST timeout (seconds)
AGENT_POST_TIMEOUT_SECS=8

# Server-side stale detection
AGENT_STALE_SECS=150
AGENT_WATCHDOG_SECS=15

# Task claim scoping and runtime concurrency
# 1 = require project_id in /tasks/claim and /tasks create
FEATURE_STRICT_CLAIM_SCOPE=1
# 0 = unlimited, >0 limits simultaneous claimed tasks per project
PER_PROJECT_MAX_WORKERS=0
# 0 = unlimited, >0 limits simultaneous claimed tasks per agent type (same working status)
PER_AGENT_TYPE_MAX_WORKERS=0

# run_all worker topology
# workers per (project, agent_type)
PROJECT_WORKERS_PER_AGENT=1
# include projects with zero open tasks when auto-spawning workers
INCLUDE_IDLE_RUNTIME_PROJECTS=0
# optional allowlist (comma-separated project IDs), empty means auto-discover
AGENT_PROJECT_IDS=

# Cross-agent commit sync strategy: cherry-pick / merge / none
HANDOFF_SYNC_STRATEGY=cherry-pick

# Codex compatibility: keep output_schema off by default.
# Set to 1 only if your codex version fully supports JSON schema subset used here.
CODEX_ENABLE_OUTPUT_SCHEMA=0

# Built-in support chat model (OpenAI-compatible API)
SUPPORT_LLM_BASE_URL=http://192.168.0.29:6006/v1
SUPPORT_LLM_MODEL=Qwen3.5-35B-A3B-FP8
# Optional if your gateway requires Bearer auth
SUPPORT_LLM_API_KEY=
# stream read uses no timeout by default; this controls pool wait timeout
SUPPORT_LLM_POOL_TIMEOUT_SECS=45
# timeout for startup health check endpoint (/runtime/support-chat/health)
SUPPORT_LLM_HEALTH_READ_TIMEOUT_SECS=8
# 0=不返回 reasoning/thinking；1=以独立事件返回（前端折叠显示思考过程）
SUPPORT_CHAT_INCLUDE_REASONING=1
# reasoning 折叠面板最多保留字符数（避免超长思考导致前端卡顿）
SUPPORT_CHAT_REASONING_MAX_CHARS=6000
