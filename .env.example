# Server config
SERVER_URL=http://localhost:8080
POLL_INTERVAL=5

# CLI timeout in seconds per task
CLI_TIMEOUT=300

# Cross-agent commit sync strategy: cherry-pick / merge / none
HANDOFF_SYNC_STRATEGY=cherry-pick

# Codex compatibility: keep output_schema off by default.
# Set to 1 only if your codex version fully supports JSON schema subset used here.
CODEX_ENABLE_OUTPUT_SCHEMA=0
